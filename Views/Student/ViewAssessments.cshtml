@model IEnumerable<SchoolProject.Models.Assessment>
@{
    ViewData["Title"] = "Module Assessments";
    Layout = "~/Views/Shared/_StudentLayout.cshtml";
}

<div class="page-header">
    <div>
        <div class="breadcrumb-custom">
            <a href="/Student/Dashboard">Dashboard</a>
            <span>/</span>
            <span>@ViewBag.ModuleName</span>
        </div>
        <h1>@ViewBag.ModuleName</h1>
        <p>View and update your assessment statuses.</p>
    </div>
    <a href="/Student/Dashboard" class="btn-secondary-custom">
        <i class="bi bi-arrow-left"></i> Back to Modules
    </a>
</div>

<div class="card">
    <div class="card-header-custom">
        <h5><i class="bi bi-card-checklist me-2" style="color:var(--primary);"></i>Assessments</h5>
        <span class="badge-custom badge-pending">@Model.Count() items</span>
    </div>
    <div style="overflow-x:auto;">
        <table class="table-custom">
            <thead>
                <tr>
                    <th>Type</th>
                    <th>Due Date</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var a in Model)
                    {
                        <tr>
                            <td><strong>@a.AssessmentType.AssessmentTypeDescription</strong></td>
                            <td>@a.DueDate.ToString("dd MMM yyyy")</td>
                            <td>
                                @switch (a.AssessmentStatus)
                                {
                                    case AssessmentStatus.Completed:
                                        <span class="badge-custom badge-completed">Completed</span>
                                        break;
                                    case AssessmentStatus.Missed:
                                        <span class="badge-custom badge-missed">Missed</span>
                                        break;
                                    case AssessmentStatus.Rescheduled:
                                        <span class="badge-custom badge-rescheduled">Rescheduled</span>
                                        break;
                                    default:
                                        <span class="badge-custom badge-notstarted">Not Started</span>
                                        break;
                                }
                            </td>
                            <td>
                                <a href="/Student/UpdateAssessmentStatus/@a.AssessmentID" class="btn-primary-custom" style="padding:6px 14px; font-size:13px;">
                                    <i class="bi bi-pencil-square"></i> Update
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center py-4" style="color:var(--muted);">
                            <i class="bi bi-inbox" style="font-size:28px; display:block; margin-bottom:6px;"></i>
                            No assessments available for this module.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Styles {
    <partial name="_BadgeStyles" />
}