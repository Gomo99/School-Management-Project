@model SchoolProject.Models.StudentModule
@{
    ViewData["Title"] = "Enrol Student";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

<div class="page-header">
    <div>
        <div class="breadcrumb-custom">
            <a href="/Admin/Dashboard">Dashboard</a>
            <span>/</span>
            <a href="/Admin/ManageStudentModule">Student Modules</a>
            <span>/</span> Enrol
        </div>
        <h1>Enrol Student</h1>
        <p>Assign a student to a lecturer's module.</p>
    </div>
    <a href="/Admin/ManageStudentModule" class="btn-secondary-custom">
        <i class="bi bi-arrow-left"></i> Back
    </a>
</div>

<div style="max-width:640px;">
    <div class="card">
        <div class="card-header-custom">
            <h5><i class="bi bi-journal-plus me-2" style="color:var(--primary);"></i>Enrolment Details</h5>
        </div>
        <div class="card-body-custom">
            <form asp-action="AddStudentModules" method="post">
                @Html.AntiForgeryToken()

                <div class="form-group-custom">
                    <label class="form-label-custom">Student <span style="color:var(--danger);">*</span></label>
                    <select asp-for="UserID" asp-items="@ViewData["UserID"] as Microsoft.AspNetCore.Mvc.Rendering.SelectList" class="form-control-custom form-select-custom">
                        <option value="">-- Select Student --</option>
                    </select>
                    <span asp-validation-for="UserID" class="form-error"></span>
                </div>

                <div class="form-group-custom">
                    <label class="form-label-custom">Lecturer Module <span style="color:var(--danger);">*</span></label>
                    <select asp-for="LecturerModuleID" asp-items="@ViewData["LecturerModuleID"] as Microsoft.AspNetCore.Mvc.Rendering.SelectList" class="form-control-custom form-select-custom">
                        <option value="">-- Select Lecturer & Module --</option>
                    </select>
                    <div class="form-hint">Shows lecturer name and associated module.</div>
                    <span asp-validation-for="LecturerModuleID" class="form-error"></span>
                </div>

                <div class="form-group-custom">
                    <label asp-for="Date" class="form-label-custom">Enrolment Date <span style="color:var(--danger);">*</span></label>
                    <input asp-for="Date" type="date" class="form-control-custom"
                           value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                    <span asp-validation-for="Date" class="form-error"></span>
                </div>

                <div class="d-flex gap-2 mt-2">
                    <button type="submit" class="btn-primary-custom">
                        <i class="bi bi-check-lg"></i> Enrol Student
                    </button>
                    <a href="/Admin/ManageStudentModule" class="btn-secondary-custom">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
