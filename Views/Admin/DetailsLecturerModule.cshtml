@model SchoolProject.Models.LecturerModule
@{
    ViewData["Title"] = "Assignment Details";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

<div class="page-header">
    <div>
        <div class="breadcrumb-custom">
            <a href="/Admin/Dashboard">Dashboard</a>
            <span>/</span>
            <a href="/Admin/ManageLecturerModules">Lecturer Modules</a>
            <span>/</span> Details
        </div>
        <h1>Assignment Details</h1>
    </div>
    <div class="d-flex gap-2">
        <a href="/Admin/EditLecturerModule/@Model.LecturerModuleID" class="btn-primary-custom">
            <i class="bi bi-pencil"></i> Edit
        </a>
        <a href="/Admin/ManageLecturerModules" class="btn-secondary-custom">
            <i class="bi bi-arrow-left"></i> Back
        </a>
    </div>
</div>

<div style="max-width:640px;">
    <div class="card">
        <div class="card-header-custom">
            <h5><i class="bi bi-person-workspace me-2" style="color:var(--primary);"></i>Lecturer–Module Assignment</h5>
            @if (Model.ModLecturerStatus.ToString() == "Active")
            {
                <span class="badge-custom badge-active">Active</span>
            }
            else
            {
                <span class="badge-custom badge-inactive">Inactive</span>
            }
        </div>
        <div class="card-body-custom">
            <div class="detail-row">
                <div class="detail-label">Assignment ID</div>
                <div class="detail-value" style="font-family:'Outfit',sans-serif; font-weight:600; color:var(--primary);">#@Model.LecturerModuleID</div>
            </div>
            <div class="detail-row">
                <div class="detail-label">Lecturer Name</div>
                <div class="detail-value"><strong>@Model.Lecturer?.Name @Model.Lecturer?.Surname</strong></div>
            </div>
            <div class="detail-row">
                <div class="detail-label">Lecturer Email</div>
                <div class="detail-value"><a href="mailto:@Model.Lecturer?.Email" style="color:var(--primary);">@Model.Lecturer?.Email</a></div>
            </div>
            <div class="detail-row">
                <div class="detail-label">Module</div>
                <div class="detail-value"><strong>@Model.Module?.ModuleName</strong></div>
            </div>
            <div class="detail-row">
                <div class="detail-label">Module Type</div>
                <div class="detail-value">
                    <span class="badge-custom badge-student">@Model.Module?.ModuleType</span>
                </div>
            </div>
            <div class="detail-row">
                <div class="detail-label">Duration</div>
                <div class="detail-value">@Model.Module?.Duration weeks</div>
            </div>
            <div class="detail-row">
                <div class="detail-label">Assigned Date</div>
                <div class="detail-value">@Model.AssignedDate.ToString("dddd, dd MMMM yyyy")</div>
            </div>
            <div class="detail-row">
                <div class="detail-label">Status</div>
                <div class="detail-value">
                    @if (Model.ModLecturerStatus.ToString() == "Active")
                    {
                        <span class="badge-custom badge-active">Active</span>
                    }
                    else
                    {
                        <span class="badge-custom badge-inactive">Inactive</span>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2 mt-3">
        <a href="/Admin/EditLecturerModule/@Model.LecturerModuleID" class="btn-primary-custom">
            <i class="bi bi-pencil"></i> Edit
        </a>
        <a href="/Admin/DeleteLecturerModule/@Model.LecturerModuleID" class="btn-danger-custom">
            <i class="bi bi-trash"></i> Remove
        </a>
    </div>
</div>
