@model SchoolProject.Models.LecturerModule
@{
    ViewData["Title"] = "Edit Lecturer Module";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

<div class="page-header">
    <div>
        <div class="breadcrumb-custom">
            <a href="/Admin/Dashboard">Dashboard</a>
            <span>/</span>
            <a href="/Admin/ManageLecturerModules">Lecturer Modules</a>
            <span>/</span> Edit
        </div>
        <h1>Edit Assignment</h1>
        <p>Update the lecturer-module assignment details.</p>
    </div>
    <a href="/Admin/ManageLecturerModules" class="btn-secondary-custom">
        <i class="bi bi-arrow-left"></i> Back
    </a>
</div>

<div style="max-width:640px;">
    <div class="card">
        <div class="card-header-custom">
            <h5><i class="bi bi-pencil-fill me-2" style="color:var(--primary);"></i>Assignment Details</h5>
            <span class="badge-custom badge-student">#@Model.LecturerModuleID</span>
        </div>
        <div class="card-body-custom">
            <form asp-action="EditLecturerModule" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="LecturerModuleID" type="hidden" />

                <div class="form-group-custom">
                    <label class="form-label-custom">Lecturer <span style="color:var(--danger);">*</span></label>
                    <select asp-for="UserID" asp-items="ViewBag.LecturerList" class="form-control-custom form-select-custom">
                        <option value="">-- Select Lecturer --</option>
                    </select>
                    <span asp-validation-for="UserID" class="form-error"></span>
                </div>

                <div class="form-group-custom">
                    <label class="form-label-custom">Module <span style="color:var(--danger);">*</span></label>
                    <select asp-for="ModuleID" asp-items="ViewBag.ModuleList" class="form-control-custom form-select-custom">
                        <option value="">-- Select Module --</option>
                    </select>
                    <span asp-validation-for="ModuleID" class="form-error"></span>
                </div>

                <div class="form-group-custom">
                    <label asp-for="AssignedDate" class="form-label-custom">Assigned Date</label>
                    <input asp-for="AssignedDate" type="date" class="form-control-custom" />
                    <span asp-validation-for="AssignedDate" class="form-error"></span>
                </div>

                <div class="d-flex gap-2 mt-2">
                    <button type="submit" class="btn-primary-custom">
                        <i class="bi bi-check-lg"></i> Save Changes
                    </button>
                    <a href="/Admin/ManageLecturerModules" class="btn-secondary-custom">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
