@model SchoolProject.Models.Module
@{
    ViewData["Title"] = "Module Details";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

<div class="page-header">
    <div>
        <div class="breadcrumb-custom">
            <a href="/Admin/Dashboard">Dashboard</a>
            <span>/</span>
            <a href="/Admin/ManageModules">Modules</a>
            <span>/</span> Details
        </div>
        <h1>Module Details</h1>
    </div>
    <div class="d-flex gap-2">
        <a href="/Admin/EditModule/@Model.ModuleID" class="btn-primary-custom">
            <i class="bi bi-pencil"></i> Edit
        </a>
        <a href="/Admin/ManageModules" class="btn-secondary-custom">
            <i class="bi bi-arrow-left"></i> Back
        </a>
    </div>
</div>

<div style="max-width:640px;">
    <div class="card">
        <div class="card-header-custom">
            <h5><i class="bi bi-book-fill me-2" style="color:var(--primary);"></i>@Model.ModuleName</h5>
            @if (Model.ModuleStatus.ToString() == "Active")
            {
                <span class="badge-custom badge-active"><i class="bi bi-circle-fill me-1" style="font-size:7px;"></i>Active</span>
            }
            else
            {
                <span class="badge-custom badge-inactive"><i class="bi bi-circle-fill me-1" style="font-size:7px;"></i>Inactive</span>
            }
        </div>
        <div class="card-body-custom">
            <div class="detail-row">
                <div class="detail-label">Module ID</div>
                <div class="detail-value" style="font-family:'Outfit',sans-serif; font-weight:600; color:var(--primary);">#@Model.ModuleID</div>
            </div>
            <div class="detail-row">
                <div class="detail-label">Module Name</div>
                <div class="detail-value"><strong>@Model.ModuleName</strong></div>
            </div>
            <div class="detail-row">
                <div class="detail-label">Duration</div>
                <div class="detail-value">@Model.Duration weeks</div>
            </div>
            <div class="detail-row">
                <div class="detail-label">Module Type</div>
                <div class="detail-value">
                    <span class="badge-custom badge-student">@Model.ModuleType</span>
                </div>
            </div>
            <div class="detail-row">
                <div class="detail-label">Status</div>
                <div class="detail-value">
                    @if (Model.ModuleStatus.ToString() == "Active")
                    {
                        <span class="badge-custom badge-active">Active</span>
                    }
                    else
                    {
                        <span class="badge-custom badge-inactive">Inactive</span>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2 mt-3">
        <a href="/Admin/EditModule/@Model.ModuleID" class="btn-primary-custom">
            <i class="bi bi-pencil"></i> Edit Module
        </a>
        <a href="/Admin/DeleteModule/@Model.ModuleID" class="btn-danger-custom">
            <i class="bi bi-trash"></i> Deactivate
        </a>
    </div>
</div>
