@model SchoolProject.Models.StudentModule
@{
    ViewData["Title"] = "Edit Student Enrolment";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

<div class="page-header">
    <div>
        <div class="breadcrumb-custom">
            <a href="/Admin/Dashboard">Dashboard</a>
            <span>/</span>
            <a href="/Admin/ManageStudentModule">Student Modules</a>
            <span>/</span> Edit
        </div>
        <h1>Edit Enrolment</h1>
        <p>Update student module enrolment details.</p>
    </div>
    <a href="/Admin/ManageStudentModule" class="btn-secondary-custom">
        <i class="bi bi-arrow-left"></i> Back
    </a>
</div>

<div style="max-width:640px;">
    <div class="card">
        <div class="card-header-custom">
            <h5><i class="bi bi-pencil-fill me-2" style="color:var(--primary);"></i>Enrolment Details</h5>
            <span class="badge-custom badge-student">#@Model.StudentModuleID</span>
        </div>
        <div class="card-body-custom">
            <form asp-action="EditStudentModule" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="StudentModuleID" type="hidden" />

                <div class="form-group-custom">
                    <label class="form-label-custom">Student <span style="color:var(--danger);">*</span></label>
                    <select asp-for="UserID" asp-items="@(ViewData["UserID"] as SelectList)" class="form-control-custom form-select-custom">
                        <option value="">-- Select Student --</option>
                    </select>
                    <span asp-validation-for="UserID" class="form-error"></span>
                </div>

                <div class="form-group-custom">
                    <label class="form-label-custom">Lecturer Module <span style="color:var(--danger);">*</span></label>
                    <select asp-for="LecturerModuleID" asp-items="@(ViewData["LecturerModuleID"] as SelectList)" class="form-control-custom form-select-custom">
                        <option value="">-- Select Lecturer & Module --</option>
                    </select>
                    <span asp-validation-for="LecturerModuleID" class="form-error"></span>
                </div>

                <div class="form-group-custom">
                    <label asp-for="Date" class="form-label-custom">Enrolment Date</label>
                    <input asp-for="Date" type="date" class="form-control-custom" />
                    <span asp-validation-for="Date" class="form-error"></span>
                </div>

                <div class="d-flex gap-2 mt-2">
                    <button type="submit" class="btn-primary-custom">
                        <i class="bi bi-check-lg"></i> Save Changes
                    </button>
                    <a href="/Admin/ManageStudentModule" class="btn-secondary-custom">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
