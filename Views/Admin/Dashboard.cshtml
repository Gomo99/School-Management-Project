@model SchoolProject.ViewModel.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

<div class="page-header">
    <div>
        <h1>Welcome back 👋</h1>
        <p>Here's what's happening with your school management system.</p>
    </div>
</div>

<!-- Stat Cards -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon blue"><i class="bi bi-book-fill"></i></div>
            <div>
                <div class="stat-label">Active Modules</div>
                <div class="stat-value">@Model.ActiveModulesCount</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon red"><i class="bi bi-book"></i></div>
            <div>
                <div class="stat-label">Inactive Modules</div>
                <div class="stat-value">@Model.InactiveModulesCount</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon green"><i class="bi bi-people-fill"></i></div>
            <div>
                <div class="stat-label">Total Modules</div>
                <div class="stat-value">@(Model.ActiveModulesCount + Model.InactiveModulesCount)</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon amber"><i class="bi bi-person-check-fill"></i></div>
            <div>
                <div class="stat-label">Recent Accounts</div>
                <div class="stat-value">@Model.RecentAccounts?.Count</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Recent Accounts -->
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header-custom">
                <h5><i class="bi bi-clock-history me-2 text-primary"></i>Recently Added Accounts</h5>
                <a href="/Admin/ManageUsers" class="btn-secondary-custom" style="padding:6px 14px; font-size:13px;">
                    View All <i class="bi bi-arrow-right"></i>
                </a>
            </div>
            <div style="overflow-x:auto;">
                <table class="table-custom">
                    <thead>
                        <tr>
                            <th>#ID</th>
                            <th>Name</th>
                            <th>Surname</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.RecentAccounts != null && Model.RecentAccounts.Any())
                        {
                            @foreach (var acc in Model.RecentAccounts)
                            {
                                <tr>
                                    <td><span style="font-family:'Outfit',sans-serif; font-weight:600; color:var(--primary);">#@acc.UserID</span></td>
                                    <td>@acc.Name</td>
                                    <td>@acc.Surname</td>
                                    <td>
                                        <a href="/Admin/EditUser/@acc.UserID" class="btn-icon edit"><i class="bi bi-pencil"></i></a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center py-4" style="color:var(--muted);">
                                    <i class="bi bi-inbox" style="font-size:28px; display:block; margin-bottom:6px;"></i>
                                    No accounts found.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Quick Links -->
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header-custom">
                <h5><i class="bi bi-lightning-charge-fill me-2 text-warning"></i>Quick Actions</h5>
            </div>
            <div class="card-body-custom d-flex flex-column gap-2">
                <a href="/Admin/CreateModule" class="btn-primary-custom justify-content-start">
                    <i class="bi bi-plus-circle-fill"></i> Add New Module
                </a>
                <a href="/Admin/CreateUser" class="btn-primary-custom justify-content-start" style="background:#6366f1;">
                    <i class="bi bi-person-plus-fill"></i> Add New User
                </a>
                <a href="/Admin/AddLecturerModule" class="btn-primary-custom justify-content-start" style="background:var(--success);">
                    <i class="bi bi-person-workspace"></i> Assign Lecturer Module
                </a>
                <a href="/Admin/AddStudentModules" class="btn-primary-custom justify-content-start" style="background:var(--accent);">
                    <i class="bi bi-journal-plus"></i> Enrol Student Module
                </a>
            </div>
        </div>
    </div>
</div>
