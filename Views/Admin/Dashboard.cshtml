@model SchoolProject.ViewModel.DashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<style>
    .dashboard-header {
        margin-bottom: 2rem;
    }

    .dashboard-title {
        color: white;
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
    }

    .dashboard-subtitle {
        color: rgba(255, 255, 255, 0.8);
        font-size: 1.2rem;
    }

    .stat-card {
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 20px;
        padding: 2rem;
        height: 100%;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

    .stat-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 4px;
        background: linear-gradient(90deg, #4facfe 0%, #00f2fe 100%);
    }

    .stat-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
    }

    .stat-icon {
        font-size: 3rem;
        margin-bottom: 1rem;
        width: 70px;
        height: 70px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 15px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }

    .stat-content {
        color: white;
    }

    .stat-label {
        font-size: 1rem;
        opacity: 0.9;
        margin-bottom: 0.5rem;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .stat-value {
        font-size: 3rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
    }

    .stat-change {
        font-size: 0.9rem;
        padding: 0.25rem 0.75rem;
        border-radius: 20px;
        display: inline-block;
    }

    .stat-change.positive {
        background: rgba(79, 172, 254, 0.2);
        color: #4facfe;
    }

    .stat-change.negative {
        background: rgba(245, 87, 108, 0.2);
        color: #f5576c;
    }

    .quick-actions {
        margin-top: 2rem;
    }

    .action-card {
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 20px;
        padding: 1.5rem;
        text-align: center;
        transition: all 0.3s ease;
        text-decoration: none;
        display: block;
        color: white;
    }

    .action-card:hover {
        transform: translateY(-5px);
        background: rgba(255, 255, 255, 0.15);
        color: white;
    }

    .action-icon {
        font-size: 2.5rem;
        margin-bottom: 1rem;
        background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .action-title {
        font-weight: 600;
        font-size: 1.1rem;
    }

    .chart-container {
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 20px;
        padding: 2rem;
        margin-top: 2rem;
        color: white;
    }

    .chart-title {
        font-size: 1.5rem;
        font-weight: 700;
        margin-bottom: 1.5rem;
    }

    .recent-activity {
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 20px;
        padding: 2rem;
        margin-top: 2rem;
        color: white;
    }

    .activity-item {
        padding: 1rem;
        border-left: 3px solid #4facfe;
        margin-bottom: 1rem;
        background: rgba(255, 255, 255, 0.05);
        border-radius: 8px;
    }

    .activity-time {
        font-size: 0.875rem;
        opacity: 0.7;
    }
</style>

<div class="dashboard-header">
    <h1 class="dashboard-title">
        <i class="fas fa-tachometer-alt"></i> Administrator Dashboard
    </h1>
    <p class="dashboard-subtitle">
        Welcome back, @User.Identity.Name! Here's what's happening today.
    </p>
</div>

<!-- Statistics Cards -->
<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon">
                <i class="fas fa-book"></i>
            </div>
            <div class="stat-content">
                <div class="stat-label">Active Modules</div>
                <div class="stat-value">@Model.ActiveModulesCount</div>
                <span class="stat-change positive">
                    <i class="fas fa-arrow-up"></i> Active
                </span>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon">
                <i class="fas fa-book-dead"></i>
            </div>
            <div class="stat-content">
                <div class="stat-label">Inactive Modules</div>
                <div class="stat-value">@Model.InactiveModulesCount</div>
                <span class="stat-change negative">
                    <i class="fas fa-arrow-down"></i> Inactive
                </span>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon">
                <i class="fas fa-users"></i>
            </div>
            <div class="stat-content">
                <div class="stat-label">Total Users</div>
                <div class="stat-value" id="totalUsers">0</div>
                <span class="stat-change positive">
                    <i class="fas fa-chart-line"></i> Growing
                </span>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon">
                <i class="fas fa-clipboard-check"></i>
            </div>
            <div class="stat-content">
                <div class="stat-label">Assessments</div>
                <div class="stat-value" id="totalAssessments">0</div>
                <span class="stat-change positive">
                    <i class="fas fa-tasks"></i> Tracked
                </span>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="quick-actions">
    <h2 class="text-white mb-3" style="font-size: 1.8rem; font-weight: 700;">
        <i class="fas fa-bolt"></i> Quick Actions
    </h2>
    <div class="row g-4">
        <div class="col-md-3">
            <a href="/Admin/CreateUser" class="action-card">
                <div class="action-icon">
                    <i class="fas fa-user-plus"></i>
                </div>
                <div class="action-title">Add User</div>
            </a>
        </div>
        <div class="col-md-3">
            <a href="/Admin/CreateModule" class="action-card">
                <div class="action-icon">
                    <i class="fas fa-book-medical"></i>
                </div>
                <div class="action-title">Create Module</div>
            </a>
        </div>
        <div class="col-md-3">
            <a href="/Admin/AssignLecturer" class="action-card">
                <div class="action-icon">
                    <i class="fas fa-chalkboard-teacher"></i>
                </div>
                <div class="action-title">Assign Lecturer</div>
            </a>
        </div>
        <div class="col-md-3">
            <a href="/Admin/EnrollStudent" class="action-card">
                <div class="action-icon">
                    <i class="fas fa-user-graduate"></i>
                </div>
                <div class="action-title">Enroll Student</div>
            </a>
        </div>
        <div class="col-md-3">
            <a href="/Admin/ManageUsers" class="action-card">
                <div class="action-icon">
                    <i class="fas fa-users-cog"></i>
                </div>
                <div class="action-title">Manage Users</div>
            </a>
        </div>
        <div class="col-md-3">
            <a href="/Admin/ManageModules" class="action-card">
                <div class="action-icon">
                    <i class="fas fa-book-reader"></i>
                </div>
                <div class="action-title">Manage Modules</div>
            </a>
        </div>
        <div class="col-md-3">
            <a href="/Admin/UserReport" class="action-card">
                <div class="action-icon">
                    <i class="fas fa-chart-pie"></i>
                </div>
                <div class="action-title">User Reports</div>
            </a>
        </div>
        <div class="col-md-3">
            <a href="/Admin/AssessmentReport" class="action-card">
                <div class="action-icon">
                    <i class="fas fa-file-contract"></i>
                </div>
                <div class="action-title">Assessment Reports</div>
            </a>
        </div>
    </div>
</div>

<!-- Charts Section -->
<div class="row g-4 mt-2">
    <div class="col-md-6">
        <div class="chart-container">
            <h3 class="chart-title">
                <i class="fas fa-chart-bar"></i> Module Status Overview
            </h3>
            <canvas id="moduleChart"></canvas>
        </div>
    </div>
    <div class="col-md-6">
        <div class="chart-container">
            <h3 class="chart-title">
                <i class="fas fa-chart-line"></i> User Distribution
            </h3>
            <canvas id="userChart"></canvas>
        </div>
    </div>
</div>

<!-- Recent Activity -->
<div class="recent-activity">
    <h3 class="chart-title">
        <i class="fas fa-history"></i> Recent Activity
    </h3>
    <div class="activity-item">
        <div><strong>New Module Created</strong></div>
        <div class="activity-time">
            <i class="fas fa-clock"></i> Today at @DateTime.Now.ToString("hh:mm tt")
        </div>
    </div>
    <div class="activity-item">
        <div><strong>User Account Activated</strong></div>
        <div class="activity-time">
            <i class="fas fa-clock"></i> 2 hours ago
        </div>
    </div>
    <div class="activity-item">
        <div><strong>Assessment Type Updated</strong></div>
        <div class="activity-time">
            <i class="fas fa-clock"></i> 5 hours ago
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Animate counter
        function animateValue(id, start, end, duration) {
            let obj = document.getElementById(id);
            let range = end - start;
            let current = start;
            let increment = end > start ? 1 : -1;
            let stepTime = Math.abs(Math.floor(duration / range));
            let timer = setInterval(function() {
                current += increment;
                obj.innerHTML = current;
                if (current == end) {
                    clearInterval(timer);
                }
            }, stepTime);
        }

        // Simulate data (replace with actual values from your backend)
        animateValue("totalUsers", 0, 150, 2000);
        animateValue("totalAssessments", 0, 487, 2000);

        // Module Status Chart
        const moduleCtx = document.getElementById('moduleChart').getContext('2d');
        const moduleChart = new Chart(moduleCtx, {
            type: 'doughnut',
            data: {
                labels: ['Active Modules', 'Inactive Modules'],
                datasets: [{
                    data: [@Model.ActiveModulesCount, @Model.InactiveModulesCount],
                    backgroundColor: [
                        'rgba(79, 172, 254, 0.8)',
                        'rgba(245, 87, 108, 0.8)'
                    ],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            color: 'white',
                            padding: 20,
                            font: {
                                size: 14
                            }
                        }
                    }
                }
            }
        });

        // User Distribution Chart
        const userCtx = document.getElementById('userChart').getContext('2d');
        const userChart = new Chart(userCtx, {
            type: 'bar',
            data: {
                labels: ['Students', 'Lecturers', 'Admins'],
                datasets: [{
                    label: 'User Count',
                    data: [120, 25, 5],
                    backgroundColor: [
                        'rgba(102, 126, 234, 0.8)',
                        'rgba(118, 75, 162, 0.8)',
                        'rgba(79, 172, 254, 0.8)'
                    ],
                    borderWidth: 0,
                    borderRadius: 8
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    legend: {
                        display: false
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            color: 'white'
                        },
                        grid: {
                            color: 'rgba(255, 255, 255, 0.1)'
                        }
                    },
                    x: {
                        ticks: {
                            color: 'white'
                        },
                        grid: {
                            display: false
                        }
                    }
                }
            }
        });
    </script>
}
