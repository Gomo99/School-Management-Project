@model SchoolProject.ViewModel.AssignLecturerModulesViewModel
@{
    ViewData["Title"] = "Assign Lecturer to Modules";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

<div class="page-header">
    <div>
        <div class="breadcrumb-custom">
            <a href="/Admin/Dashboard">Dashboard</a>
            <span>/</span>
            <a href="/Admin/ManageLecturerModules">Lecturer Modules</a>
            <span>/</span> Assign
        </div>
        <h1>Assign Lecturer to Modules</h1>
        <p>Select a lecturer and tick the modules to assign. Multiple modules can be chosen.</p>
    </div>
    <a href="/Admin/ManageLecturerModules" class="btn-secondary-custom">
        <i class="bi bi-arrow-left"></i> Back
    </a>
</div>

<div style="max-width:680px;">
    <div class="card">
        <div class="card-header-custom">
            <h5><i class="bi bi-person-workspace me-2" style="color:var(--primary);"></i>Assignment Details</h5>
        </div>
        <div class="card-body-custom">
            <form asp-action="AssignLecturer" method="post">
                @Html.AntiForgeryToken()

                <div class="form-group-custom">
                    <label class="form-label-custom">Lecturer <span style="color:var(--danger);">*</span></label>
                    <select name="userId" class="form-control-custom form-select-custom" asp-items="ViewBag.Lecturers">
                        <option value="">-- Select Lecturer --</option>
                    </select>
                </div>

                <div class="form-group-custom">
                    <label class="form-label-custom">Modules <span style="color:var(--danger);">*</span></label>
                    <div style="border:1.5px solid var(--border); border-radius:8px; padding:4px; max-height:220px; overflow-y:auto;">
                        @if (ViewBag.Modules is List<SchoolProject.Models.Module> moduleList)
                        {
                            @foreach (var module in moduleList)
                            {
                                <label style="display:flex;align-items:center;gap:10px;padding:10px 12px;cursor:pointer;border-radius:6px;transition:background .15s;" onmouseover="this.style.background='#f0f4f9'" onmouseout="this.style.background='transparent'">
                                    <input type="checkbox" name="moduleIds" value="@module.ModuleID"
                                           @(Model.SelectedModuleIDs?.Contains(module.ModuleID) == true ? "checked" : "")
                                           style="width:16px;height:16px;accent-color:var(--primary);" />
                                    <span style="font-size:14px;">@module.ModuleName</span>
                                </label>
                            }
                        }
                    </div>
                    <div class="form-hint">Tick one or more modules to assign them to the selected lecturer.</div>
                </div>

                <div class="form-group-custom">
                    <label class="form-label-custom">Assignment Date <span style="color:var(--danger);">*</span></label>
                    <input name="assignedDate" type="date" class="form-control-custom"
                           value="@Model.AssignedDate.ToString("yyyy-MM-dd")" />
                </div>

                <div class="d-flex gap-2 mt-2">
                    <button type="submit" class="btn-primary-custom">
                        <i class="bi bi-check-lg"></i> Assign Modules
                    </button>
                    <a href="/Admin/ManageLecturerModules" class="btn-secondary-custom">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}