@model IEnumerable<SchoolProject.Models.Module>
@{
    ViewData["Title"] = "Manage Modules";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

<div class="page-header">
    <div>
        <div class="breadcrumb-custom">
            <a href="/Admin/Dashboard">Dashboard</a>
            <span>/</span> Modules
        </div>
        <h1>Modules</h1>
        <p>Create, edit and manage academic modules.</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a href="/Admin/ExportModulesPdf" class="btn-secondary-custom">
            <i class="bi bi-file-earmark-pdf"></i> Export PDF
        </a>
        <a href="/Admin/CreateModule" class="btn-primary-custom">
            <i class="bi bi-plus-lg"></i> New Module
        </a>
    </div>
</div>

<div class="card">
    <div class="card-header-custom">
        <h5><i class="bi bi-book-fill me-2" style="color:var(--primary);"></i>Active Modules</h5>
        <form method="get" action="/Admin/ExportModulesPdf" class="search-wrap">
            <i class="bi bi-search"></i>
            <input type="text" name="searchString" class="form-control-custom" placeholder="Search modules…" style="height:36px;" />
        </form>
    </div>
    <div style="overflow-x:auto;">
        <table class="table-custom">
            <thead>
                <tr>
                    <th>#ID</th>
                    <th>Module Name</th>
                    <th>Duration</th>
                    <th>Type</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var module in Model)
                    {
                        <tr>
                            <td><span style="font-family:'Outfit',sans-serif; font-weight:600; color:var(--primary);">#@module.ModuleID</span></td>
                            <td><strong>@module.ModuleName</strong></td>
                            <td>@module.Duration <span style="color:var(--muted); font-size:12px;">weeks</span></td>
                            <td>
                                <span class="badge-custom badge-student">@module.ModuleType</span>
                            </td>
                            <td>
                                @if (module.ModuleStatus.ToString() == "Active")
                                {
                                    <span class="badge-custom badge-active"><i class="bi bi-circle-fill me-1" style="font-size:7px;"></i>Active</span>
                                }
                                else
                                {
                                    <span class="badge-custom badge-inactive"><i class="bi bi-circle-fill me-1" style="font-size:7px;"></i>Inactive</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a href="/Admin/ModuleDetails/@module.ModuleID" class="btn-icon view" title="View"><i class="bi bi-eye"></i></a>
                                    <a href="/Admin/EditModule/@module.ModuleID" class="btn-icon edit" title="Edit"><i class="bi bi-pencil"></i></a>
                                    <a href="/Admin/DeleteModule/@module.ModuleID" class="btn-icon delete" title="Delete"><i class="bi bi-trash"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center py-5" style="color:var(--muted);">
                            <i class="bi bi-folder2-open" style="font-size:36px; display:block; margin-bottom:8px;"></i>
                            No modules found. <a href="/Admin/CreateModule" style="color:var(--primary);">Create one now.</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
