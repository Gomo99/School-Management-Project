@model SchoolProject.Models.Module
@{
    ViewData["Title"] = "Delete Module";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

<div class="page-header">
    <div>
        <div class="breadcrumb-custom">
            <a href="/Admin/Dashboard">Dashboard</a>
            <span>/</span>
            <a href="/Admin/ManageModules">Modules</a>
            <span>/</span> Delete
        </div>
        <h1>Delete Module</h1>
    </div>
</div>

<div class="delete-card">
    <div class="card">
        <div class="card-body-custom text-center" style="padding:40px;">
            <div class="delete-icon-wrap">
                <i class="bi bi-exclamation-triangle-fill"></i>
            </div>

            <h3 style="font-family:'Outfit',sans-serif; font-size:22px; font-weight:700; margin-bottom:8px;">Deactivate Module?</h3>
            <p style="color:var(--muted); font-size:14px; margin-bottom:28px;">
                The module <strong style="color:var(--text);">@Model.ModuleName</strong> will be marked as
                <strong style="color:var(--danger);">Inactive</strong>. This action can be reversed later.
            </p>

            <!-- Details summary -->
            <div class="card" style="text-align:left; margin-bottom:28px; background:#f8fafc;">
                <div class="card-body-custom" style="padding:16px 20px;">
                    <div class="detail-row" style="padding:8px 0;">
                        <div class="detail-label">Module ID</div>
                        <div class="detail-value">#@Model.ModuleID</div>
                    </div>
                    <div class="detail-row" style="padding:8px 0;">
                        <div class="detail-label">Module Name</div>
                        <div class="detail-value">@Model.ModuleName</div>
                    </div>
                    <div class="detail-row" style="padding:8px 0;">
                        <div class="detail-label">Duration</div>
                        <div class="detail-value">@Model.Duration weeks</div>
                    </div>
                    <div class="detail-row" style="padding:8px 0; border-bottom:none;">
                        <div class="detail-label">Type</div>
                        <div class="detail-value">@Model.ModuleType</div>
                    </div>
                </div>
            </div>

            <form asp-action="DeleteModule" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.ModuleID" />
                <div class="d-flex gap-3 justify-content-center">
                    <a href="/Admin/ManageModules" class="btn-secondary-custom">
                        <i class="bi bi-x-lg"></i> Cancel
                    </a>
                    <button type="submit" class="btn-danger-custom">
                        <i class="bi bi-trash-fill"></i> Confirm Deactivate
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
