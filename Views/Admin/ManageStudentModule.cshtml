@model IEnumerable<SchoolProject.Models.StudentModule>
@{
    ViewData["Title"] = "Student Modules";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

<div class="page-header">
    <div>
        <div class="breadcrumb-custom">
            <a href="/Admin/Dashboard">Dashboard</a>
            <span>/</span> Student Modules
        </div>
        <h1>Student Module Enrolments</h1>
        <p>Manage student enrolments for modules.</p>
    </div>
    <a href="/Admin/AddStudentModules" class="btn-primary-custom">
        <i class="bi bi-plus-lg"></i> Enrol Student
    </a>
</div>

<div class="card">
    <div class="card-header-custom">
        <h5><i class="bi bi-journal-bookmark-fill me-2" style="color:var(--primary);"></i>Active Enrolments</h5>
        <span class="badge-custom badge-student">@Model.Count() records</span>
    </div>
    <div style="overflow-x:auto;">
        <table class="table-custom">
            <thead>
                <tr>
                    <th>#ID</th>
                    <th>Student</th>
                    <th>Lecturer</th>
                    <th>Module</th>
                    <th>Enrolled Date</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var sm in Model)
                    {
                        <tr>
                            <td><span style="font-family:'Outfit',sans-serif; font-weight:600; color:var(--primary);">#@sm.StudentModuleID</span></td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div style="width:30px;height:30px;border-radius:50%;background:#dbeafe;color:#1e40af;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:12px;">
                                        @(sm.Student?.Name?.Substring(0, 1).ToUpper())
                                    </div>
                                    <div>
                                        <div style="font-weight:600;">@sm.Student?.Name @sm.Student?.Surname</div>
                                        <div style="font-size:12px;color:var(--muted);">@sm.Student?.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td>@sm.LecturerModule?.Lecturer?.Name @sm.LecturerModule?.Lecturer?.Surname</td>
                            <td><strong>@sm.LecturerModule?.Module?.ModuleName</strong></td>
                            <td style="color:var(--muted);">@sm.Date.ToString("dd MMM yyyy")</td>
                            <td>
                                @if (sm.StudModStatus.ToString() == "Active")
                                {
                                    <span class="badge-custom badge-active">Active</span>
                                }
                                else
                                {
                                    <span class="badge-custom badge-inactive">Inactive</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a href="/Admin/EditStudentModule/@sm.StudentModuleID" class="btn-icon edit" title="Edit"><i class="bi bi-pencil"></i></a>
                                    <a href="/Admin/DeleteStudentModule/@sm.StudentModuleID" class="btn-icon delete" title="Remove"><i class="bi bi-trash"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center py-5" style="color:var(--muted);">
                            <i class="bi bi-journal-x" style="font-size:36px; display:block; margin-bottom:8px;"></i>
                            No enrolments found. <a href="/Admin/AddStudentModules" style="color:var(--primary);">Enrol a student now.</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
