<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – SchoolProject</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Nunito:wght@400;500;600&display=swap" rel="stylesheet" />
    <!-- Moment.js for time formatting -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.4/moment.min.js"></script>
    <style>
        :root {
            --sidebar-bg: #1a2744;
            --sidebar-hover: #253660;
            --sidebar-active: #10b981;
            --sidebar-text: #a8b8d8;
            --sidebar-text-active: #ffffff;
            --body-bg: #f0f4f9;
            --card-bg: #ffffff;
            --primary: #10b981;
            --primary-light: #d1fae5;
            --accent: #6366f1;
            --success: #10b981;
            --danger: #ef4444;
            --warning: #f59e0b;
            --text: #1e293b;
            --muted: #64748b;
            --border: #e2e8f0;
            --shadow: 0 2px 12px rgba(16,185,129,.08);
            --shadow-lg: 0 8px 32px rgba(16,185,129,.14);
            --radius: 12px;
            --sidebar-width: 260px;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Nunito', sans-serif;
            background: var(--body-bg);
            color: var(--text);
            min-height: 100vh;
        }

        h1, h2, h3, h4, h5, h6, .display-font {
            font-family: 'Outfit', sans-serif;
        }

        /* ── Sidebar ── */
        #sidebar {
            position: fixed;
            top: 0;
            left: 0;
            bottom: 0;
            width: var(--sidebar-width);
            background: var(--sidebar-bg);
            display: flex;
            flex-direction: column;
            z-index: 1000;
            transition: transform .28s cubic-bezier(.4,0,.2,1);
            box-shadow: 4px 0 24px rgba(0,0,0,.18);
        }

        .sidebar-brand {
            padding: 28px 24px 20px;
            border-bottom: 1px solid rgba(255,255,255,.06);
        }

            .sidebar-brand .brand-logo {
                display: flex;
                align-items: center;
                gap: 12px;
                text-decoration: none;
            }

        .brand-icon {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: linear-gradient(135deg, var(--primary), #059669);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            color: white;
            flex-shrink: 0;
        }

        .brand-text .app-name {
            font-family: 'Outfit', sans-serif;
            font-size: 17px;
            font-weight: 700;
            color: #fff;
            line-height: 1.1;
        }

        .brand-text .app-sub {
            font-size: 11px;
            color: var(--sidebar-text);
            letter-spacing: .5px;
            text-transform: uppercase;
        }

        .sidebar-nav {
            flex: 1;
            overflow-y: auto;
            padding: 16px 0;
        }

        .nav-section-label {
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 1.2px;
            text-transform: uppercase;
            color: rgba(168,184,216,.45);
            padding: 14px 24px 6px;
        }

        .nav-item a {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 24px;
            text-decoration: none;
            color: var(--sidebar-text);
            font-size: 14px;
            font-weight: 500;
            border-radius: 0;
            transition: all .18s;
            border-left: 3px solid transparent;
        }

            .nav-item a:hover {
                background: var(--sidebar-hover);
                color: var(--sidebar-text-active);
            }

            .nav-item a.active {
                background: rgba(16,185,129,.18);
                color: var(--sidebar-text-active);
                border-left-color: var(--sidebar-active);
            }

            .nav-item a i {
                font-size: 17px;
                width: 20px;
                text-align: center;
            }

        .sidebar-footer {
            padding: 16px 24px;
            border-top: 1px solid rgba(255,255,255,.06);
        }

            .sidebar-footer a {
                display: flex;
                align-items: center;
                gap: 10px;
                color: var(--sidebar-text);
                text-decoration: none;
                font-size: 14px;
                font-weight: 500;
                padding: 8px 0;
                transition: color .18s;
            }

                .sidebar-footer a:hover {
                    color: var(--danger);
                }

        /* ── Main content ── */
        #main-content {
            margin-left: var(--sidebar-width);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* ── Topbar ── */
        .topbar {
            background: var(--card-bg);
            border-bottom: 1px solid var(--border);
            padding: 14px 32px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: 0 1px 4px rgba(0,0,0,.04);
        }

        .topbar-title {
            font-family: 'Outfit', sans-serif;
            font-size: 19px;
            font-weight: 600;
            color: var(--text);
        }

        .topbar-right {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .topbar-user {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 14px;
            font-weight: 600;
            color: var(--text);
        }

        .user-avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--primary), #059669);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 14px;
            font-weight: 700;
        }

        /* ── Page body ── */
        .page-body {
            flex: 1;
            padding: 32px;
        }

        /* (rest of card, table, badge, button, form, etc. styles keep unchanged) */
        /* … copy your existing styles here … */
    </style>
    @RenderSection("Styles", required: false)
</head>
<body>

    <!-- ══ SIDEBAR ══ -->
    <aside id="sidebar">
        <div class="sidebar-brand">
            <a class="brand-logo" href="/Student/Dashboard">
                <div class="brand-icon"><i class="bi bi-mortarboard-fill"></i></div>
                <div class="brand-text">
                    <div class="app-name">SchoolProject</div>
                    <div class="app-sub">Student Portal</div>
                </div>
            </a>
        </div>

        <nav class="sidebar-nav">
            <div class="nav-section-label">Overview</div>
            <div class="nav-item">
                <a href="/Student/Dashboard" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Dashboard" ? "active" : "")">
                    <i class="bi bi-grid-1x2-fill"></i> Dashboard
                </a>
            </div>

            <div class="nav-section-label">My Modules</div>
            <div class="nav-item">
                <a href="/Student/ModuleAssessments" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "ModuleAssessments" ? "active" : "")">
                    <i class="bi bi-journal-check"></i> Assessments
                </a>
            </div>
        </nav>

        <div class="sidebar-footer">
            <form asp-action="Logout" asp-controller="Account" method="post" style="display: inline;">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-link p-0 border-0"
                        style="color: var(--sidebar-text); font-size: 14px; font-weight: 500; text-decoration: none; display: flex; align-items: center; gap: 10px;">
                    <i class="bi bi-box-arrow-left"></i> Sign Out
                </button>
            </form>
        </div>
    </aside>

    <!-- ══ MAIN ══ -->
    <div id="main-content">

        <header class="topbar">
            <div class="d-flex align-items-center gap-3">
                <button class="btn-icon d-lg-none" onclick="document.getElementById('sidebar').classList.toggle('show')"
                        style="border:none; background:none; font-size:22px; color:var(--text);">
                    <i class="bi bi-list"></i>
                </button>
                <span class="topbar-title">@ViewData["Title"]</span>
            </div>

            <div class="topbar-right">
                <!-- Notification Bell -->
                <div class="dropdown" id="notificationDropdown">
                    <button class="btn btn-link position-relative" type="button" id="bellButton" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="bi bi-bell-fill" style="font-size:1.4rem; color:var(--text);"></i>
                        <span id="notificationBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="display:none;">0</span>
                    </button>
                    <div class="dropdown-menu dropdown-menu-end shadow" style="width:350px; max-height:400px; overflow-y:auto;" aria-labelledby="bellButton">
                        <h6 class="dropdown-header">Notifications</h6>
                        <div id="notificationItems" class="px-2">
                            <div class="text-muted text-center py-3">Loading...</div>
                        </div>
                        <div class="dropdown-divider"></div>
                        <a href="#" onclick="markAllAsRead(); return false;" class="dropdown-item text-primary small">Mark all as read</a>
                    </div>
                </div>

                <div class="topbar-user">
                    <div class="user-avatar">@(User.Identity?.Name?.Substring(0, 1).ToUpper() ?? "S")</div>
                    <span>@User.Identity?.Name</span>
                </div>
            </div>
        </header>

        <div class="page-body fade-in">
            <partial name="_NotificationPartial" />

            @RenderBody()
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Get user ID from the claim (set by your SignInUser method)
            const userId = parseInt('@User.FindFirst("UserID")?.Value');
            if (!userId) return;

            // SignalR connection
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/messageHub")
                .build();

            connection.start().then(function () {
                connection.invoke("JoinUserGroup", userId).catch(console.error);
            }).catch(console.error);

            connection.on("ReceiveNotification", function (data) {
                showToast(data.message, data.type === 'deadline_reminder' ? 'warning' : 'info');
                loadNotifications();
            });

            // Initial load
            loadNotifications();

            async function loadNotifications() {
                try {
                    const res = await fetch('/Student/GetNotifications');
                    if (!res.ok) return;
                    const notifications = await res.json();
                    renderNotifications(notifications);
                    updateBadge(notifications.filter(n => !n.isRead).length);
                } catch (ex) {
                    console.error("Failed to load notifications", ex);
                }
            }

            function renderNotifications(items) {
                const container = document.getElementById('notificationItems');
                if (!items.length) {
                    container.innerHTML = '<div class="text-muted text-center py-3">No notifications</div>';
                    return;
                }
                let html = '';
                items.forEach(n => {
                    const time = moment(n.createdAt).fromNow();
                    html += `<a href="#" class="dropdown-item d-flex justify-content-between align-items-start ${n.isRead ? '' : 'fw-bold'}"
                             onclick="markAsRead(${n.notificationID}, event)">
                        <span class="me-2">${n.message}</span>
                        <small class="text-muted">${time}</small>
                    </a>`;
                });
                container.innerHTML = html;
            }

            function updateBadge(count) {
                const badge = document.getElementById('notificationBadge');
                if (count > 0) {
                    badge.style.display = 'inline-block';
                    badge.textContent = count;
                } else {
                    badge.style.display = 'none';
                }
            }

            function showToast(message, type) {
                const toastEl = document.createElement('div');
                toastEl.className = `alert alert-${type} alert-dismissible fade show position-fixed bottom-0 end-0 m-3 small`;
                toastEl.innerHTML = message + '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
                document.body.appendChild(toastEl);
                setTimeout(() => toastEl.remove(), 5000);
            }

            window.markAsRead = async function(id, event) {
                event.preventDefault();
                try {
                    await fetch(`/Student/MarkNotificationRead?id=${id}`, { method: 'POST' });
                    loadNotifications();
                } catch (ex) {
                    console.error("Mark read failed", ex);
                }
            };

            window.markAllAsRead = async function() {
                try {
                    await fetch('/Student/MarkAllNotificationsRead', { method: 'POST' });
                    loadNotifications();
                } catch (ex) {
                    console.error("Mark all read failed", ex);
                }
            };
        });
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>