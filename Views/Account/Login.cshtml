@model SchoolProject.ViewModel.LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<style>
    .login-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 70vh;
        padding: 2rem 0;
    }

    .login-card {
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 30px;
        padding: 3rem;
        box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.37);
        max-width: 500px;
        width: 100%;
        animation: fadeInUp 0.8s ease;
    }

    .login-header {
        text-align: center;
        margin-bottom: 2rem;
        color: white;
    }

    .login-icon {
        font-size: 5rem;
        background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 1rem;
    }

    .login-title {
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
    }

    .login-subtitle {
        opacity: 0.9;
    }

    .form-floating-custom {
        margin-bottom: 1.5rem;
        position: relative;
    }

    .form-floating-custom input,
    .form-floating-custom textarea {
        background: rgba(255, 255, 255, 0.9);
        border: 2px solid rgba(255, 255, 255, 0.3);
        border-radius: 12px;
        padding: 1rem;
        width: 100%;
        font-size: 1rem;
        transition: all 0.3s ease;
    }

    .form-floating-custom input:focus,
    .form-floating-custom textarea:focus {
        outline: none;
        border-color: #4facfe;
        box-shadow: 0 0 20px rgba(79, 172, 254, 0.3);
    }

    .form-floating-custom label {
        position: absolute;
        left: 1rem;
        top: 1rem;
        color: #666;
        font-size: 1rem;
        pointer-events: none;
        transition: all 0.3s ease;
    }

    .form-floating-custom input:focus + label,
    .form-floating-custom input:not(:placeholder-shown) + label {
        top: -0.5rem;
        left: 0.5rem;
        font-size: 0.75rem;
        background: white;
        padding: 0 0.5rem;
        color: #4facfe;
        border-radius: 4px;
    }

    .input-icon {
        position: absolute;
        right: 1rem;
        top: 1rem;
        color: #666;
        font-size: 1.2rem;
    }

    .checkbox-custom {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: white;
        margin-bottom: 1.5rem;
    }

    .checkbox-custom input[type="checkbox"] {
        width: 20px;
        height: 20px;
        cursor: pointer;
    }

    .btn-login {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        color: white;
        padding: 1rem;
        border-radius: 12px;
        font-weight: 600;
        font-size: 1.1rem;
        width: 100%;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px 0 rgba(102, 126, 234, 0.5);
    }

    .btn-login:hover {
        transform: translateY(-3px);
        box-shadow: 0 6px 20px 0 rgba(102, 126, 234, 0.7);
    }

    .btn-google {
        background: white;
        color: #333;
        border: 2px solid rgba(255, 255, 255, 0.3);
        padding: 1rem;
        border-radius: 12px;
        font-weight: 600;
        width: 100%;
        margin-top: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        transition: all 0.3s ease;
    }

    .btn-google:hover {
        transform: translateY(-3px);
        box-shadow: 0 4px 15px 0 rgba(0, 0, 0, 0.2);
    }

    .divider {
        text-align: center;
        margin: 1.5rem 0;
        color: white;
        position: relative;
    }

    .divider::before,
    .divider::after {
        content: '';
        position: absolute;
        top: 50%;
        width: 40%;
        height: 1px;
        background: rgba(255, 255, 255, 0.3);
    }

    .divider::before {
        left: 0;
    }

    .divider::after {
        right: 0;
    }

    .login-links {
        text-align: center;
        margin-top: 1.5rem;
        color: white;
    }

    .login-links a {
        color: #4facfe;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .login-links a:hover {
        color: #00f2fe;
        text-decoration: underline;
    }

    .validation-error {
        color: #ff6b6b;
        font-size: 0.875rem;
        margin-top: 0.25rem;
        display: block;
    }
</style>

<div class="login-container">
    <div class="login-card">
        <div class="login-header">
            <div class="login-icon">
                <i class="fas fa-graduation-cap"></i>
            </div>
            <h1 class="login-title">Welcome Back!</h1>
            <p class="login-subtitle">Sign in to continue to SchoolHub</p>
        </div>

        <form method="post" asp-action="Login">
            @Html.AntiForgeryToken()

            <div class="form-floating-custom">
                <input type="text" asp-for="Email" placeholder=" " id="emailInput" />
                <label for="emailInput">Email or Username</label>
                <i class="fas fa-user input-icon"></i>
                <span asp-validation-for="Email" class="validation-error"></span>
            </div>

            <div class="form-floating-custom">
                <input type="password" asp-for="Password" placeholder=" " id="passwordInput" />
                <label for="passwordInput">Password</label>
                <i class="fas fa-lock input-icon"></i>
                <span asp-validation-for="Password" class="validation-error"></span>
            </div>

            <div class="checkbox-custom">
                <input type="checkbox" asp-for="RememberMe" id="rememberMe" />
                <label for="rememberMe">Remember me</label>
            </div>

            <button type="submit" class="btn btn-login">
                <i class="fas fa-sign-in-alt"></i> Sign In
            </button>

            <div class="divider">OR</div>

            <button type="button" class="btn btn-google" onclick="document.getElementById('googleForm').submit();">
                <i class="fab fa-google"></i> Continue with Google
            </button>
        </form>

        <form id="googleForm" method="post" asp-action="GoogleLogin" style="display:none;">
            @Html.AntiForgeryToken()
        </form>

        <div class="login-links">
            <p>
                <a href="/Account/ForgotPassword">
                    <i class="fas fa-key"></i> Forgot Password?
                </a>
            </p>
            <p>
                <a href="/Account/ResendVerificationEmail">
                    <i class="fas fa-envelope-open-text"></i> Resend Verification Email
                </a>
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Add smooth animations to inputs
        document.querySelectorAll('.form-floating-custom input').forEach(input => {
            input.addEventListener('focus', function() {
                this.parentElement.style.transform = 'scale(1.02)';
            });
            input.addEventListener('blur', function() {
                this.parentElement.style.transform = 'scale(1)';
            });
        });
    </script>
}
