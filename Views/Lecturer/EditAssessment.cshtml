@model SchoolProject.Models.Assessment
@{
    ViewData["Title"] = "Edit Assessment";
    Layout = "~/Views/Shared/_LecturerLayout.cshtml";
}

<div class="page-header">
    <div>
        <h1>Edit Assessment</h1>
    </div>
    <a href="/Lecturer/ManageAssessments" class="btn-secondary-custom">
        <i class="bi bi-arrow-left"></i> Back
    </a>
</div>

<div style="max-width:600px;">
    <div class="card">
        <div class="card-header-custom">
            <h5><i class="bi bi-pencil-fill me-2" style="color:var(--primary);"></i>Assessment #@Model.AssessmentID</h5>
        </div>
        <div class="card-body-custom">
            <form asp-action="EditAssessment" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="AssessmentID" />
                <div class="form-group-custom">
                    <label class="form-label-custom">Student <span style="color:var(--danger);">*</span></label>
                    <select asp-for="StudentModuleID" class="form-control-custom form-select-custom"
                            asp-items="@(ViewData["StudentModuleID"] as SelectList)">
                        <option value="">-- Select Student --</option>
                    </select>
                </div>
                <div class="form-group-custom">
                    <label class="form-label-custom">Assessment Type <span style="color:var(--danger);">*</span></label>
                    <select asp-for="AssessmentTypeID" class="form-control-custom form-select-custom"
                            asp-items="@(ViewData["AssessmentTypeID"] as SelectList)">
                        <option value="">-- Select Type --</option>
                    </select>
                </div>
                <div class="form-group-custom">
                    <label asp-for="DueDate" class="form-label-custom">Due Date <span style="color:var(--danger);">*</span></label>
                    <input asp-for="DueDate" type="date" class="form-control-custom" />
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn-primary-custom"><i class="bi bi-check-lg"></i> Save</button>
                    <a href="/Lecturer/ManageAssessments" class="btn-secondary-custom">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}