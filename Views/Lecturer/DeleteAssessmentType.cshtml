@model SchoolProject.Models.AssessmentType
@{
    ViewData["Title"] = "Delete Assessment Type";
    Layout = "~/Views/Shared/_LecturerLayout.cshtml";
}

<div class="delete-card">
    <div class="card">
        <div class="card-body-custom text-center" style="padding:40px;">
            <div class="delete-icon-wrap"><i class="bi bi-exclamation-triangle-fill"></i></div>
            <h3>Delete "@Model.AssessmentTypeDescription"?</h3>
            <form asp-action="DeleteAssessmentType" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.AssessmentTypeID" />
                <div class="d-flex gap-3 justify-content-center">
                    <a href="/Lecturer/ManageAssessmentType" class="btn-secondary-custom">Cancel</a>
                    <button type="submit" class="btn-danger-custom"><i class="bi bi-trash"></i> Delete</button>
                </div>
            </form>
        </div>
    </div>
</div>