@model SchoolProject.Models.AssessmentType
@{
    ViewData["Title"] = "Add Assessment Type";
    Layout = "~/Views/Shared/_LecturerLayout.cshtml";
}

<div class="page-header">
    <div>
        <h1>New Assessment Type</h1>
    </div>
    <a href="/Lecturer/ManageAssessmentType" class="btn-secondary-custom">
        <i class="bi bi-arrow-left"></i> Back
    </a>
</div>

<div style="max-width:500px;">
    <div class="card">
        <div class="card-header-custom">
            <h5><i class="bi bi-plus-circle-fill me-2" style="color:var(--primary);"></i>Details</h5>
        </div>
        <div class="card-body-custom">
            <form asp-action="AddAssessmentType" method="post">
                @Html.AntiForgeryToken()
                <div class="form-group-custom">
                    <label asp-for="AssessmentTypeDescription" class="form-label-custom">Description <span style="color:var(--danger);">*</span></label>
                    <input asp-for="AssessmentTypeDescription" class="form-control-custom" placeholder="e.g. Assignment, Test" />
                    <span asp-validation-for="AssessmentTypeDescription" class="form-error"></span>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn-primary-custom"><i class="bi bi-check-lg"></i> Save</button>
                    <a href="/Lecturer/ManageAssessmentType" class="btn-secondary-custom">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}