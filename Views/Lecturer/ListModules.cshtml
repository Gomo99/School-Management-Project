@model IEnumerable<SchoolProject.Models.LecturerModule>
@{
    ViewData["Title"] = "My Modules";
    Layout = "~/Views/Shared/_LecturerLayout.cshtml";
}

<div class="page-header">
    <div>
        <h1>My Modules</h1>
        <p>Modules assigned to you for this semester.</p>
    </div>
</div>

<div class="card">
    <div class="card-header-custom">
        <h5><i class="bi bi-book-fill me-2" style="color:var(--primary);"></i>Active Modules</h5>
        <span class="badge-custom badge-active">@Model.Count() modules</span>
    </div>
    <div style="overflow-x:auto;">
        <table class="table-custom">
            <thead>
                <tr>
                    <th>#ID</th>
                    <th>Module Name</th>
                    <th>Duration</th>
                    <th>Type</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var lm in Model)
                    {
                        <tr>
                            <td><span style="font-family:'Outfit',sans-serif; font-weight:600; color:var(--primary);">#@lm.ModuleID</span></td>
                            <td><strong>@lm.Module.ModuleName</strong></td>
                            <td>@lm.Module.Duration weeks</td>
                            <td><span class="badge-custom badge-student">@lm.Module.ModuleType</span></td>
                            <td>
                                <span class="badge-custom badge-active">@lm.ModLecturerStatus</span>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center py-4" style="color:var(--muted);">
                            <i class="bi bi-journal-x" style="font-size:28px; display:block; margin-bottom:6px;"></i>
                            No modules assigned yet.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>