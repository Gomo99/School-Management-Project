@model IEnumerable<SchoolProject.Models.Assessment>
@{
    ViewData["Title"] = "Assessment Report";
    Layout = "~/Views/Shared/_LecturerLayout.cshtml";
}

<div class="page-header">
    <div>
        <h1>Assessment Report</h1>
        <p>Filter assessments by status, type, or date range.</p>
    </div>
</div>

<form method="get" class="row g-3 mb-4">
    <div class="col-md-3">
        <label class="form-label-custom">Status</label>
        <select name="status" class="form-control-custom form-select-custom">
            <option value="">All</option>
            @foreach (var s in ViewBag.StatusOptions)
            {
                bool selected = ViewBag.SelectedStatus?.ToString() == s.ToString();
                <option value="@s" selected="@(selected ? "selected" : null)">@s</option>
            }
        </select>
    </div>
    <div class="col-md-3">
        <label class="form-label-custom">Type</label>
        <select name="typeId" class="form-control-custom form-select-custom">
            <option value="">All</option>
            @foreach (var t in ViewBag.AssessmentTypes)
            {
                bool selected = (int?)ViewBag.SelectedTypeId == t.AssessmentTypeID;
                <option value="@t.AssessmentTypeID" selected="@(selected ? "selected" : null)">@t.AssessmentTypeDescription</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <label class="form-label-custom">From</label>
        <input type="date" name="fromDate" class="form-control-custom" value="@ViewBag.FromDate?.ToString("yyyy-MM-dd")" />
    </div>
    <div class="col-md-2">
        <label class="form-label-custom">To</label>
        <input type="date" name="toDate" class="form-control-custom" value="@ViewBag.ToDate?.ToString("yyyy-MM-dd")" />
    </div>
    <div class="col-md-2 align-self-end">
        <button type="submit" class="btn-primary-custom"><i class="bi bi-funnel"></i> Filter</button>
    </div>
</form>

<div class="card">
    <div class="card-header-custom">
        <h5><i class="bi bi-list-check me-2" style="color:var(--primary);"></i>Results</h5>
        <span class="badge-custom badge-active">@Model.Count() assessments</span>
    </div>
    <div style="overflow-x:auto;">
        <table class="table-custom">
            <thead>
                <tr>
                    <th>Student</th>
                    <th>Module</th>
                    <th>Type</th>
                    <th>Due Date</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var a in Model)
                    {
                        <tr>
                            <td>@a.StudentModule?.Student?.Name @a.StudentModule?.Student?.Surname</td>
                            <td>@a.StudentModule?.LecturerModule?.Module?.ModuleName</td>
                            <td>@a.AssessmentType?.AssessmentTypeDescription</td>
                            <td>@a.DueDate.ToString("dd MMM yyyy")</td>
                            <td>
                                @switch (a.AssessmentStatus)
                                {
                                    case AssessmentStatus.Completed:
                                        <span class="badge-custom badge-completed">Completed</span>
                                        break;
                                    case AssessmentStatus.Missed:
                                        <span class="badge-custom badge-missed">Missed</span>
                                        break;
                                    case AssessmentStatus.Rescheduled:
                                        <span class="badge-custom badge-rescheduled">Rescheduled</span>
                                        break;
                                    default:
                                        <span class="badge-custom badge-notstarted">Not Started</span>
                                        break;
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center py-4" style="color:var(--muted);">
                            <i class="bi bi-inbox" style="font-size:28px; display:block; margin-bottom:6px;"></i>
                            No assessments match the filter.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>