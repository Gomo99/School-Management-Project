@model IEnumerable<SchoolProject.Models.Account>
@{
    ViewData["Title"] = "My Students";
    Layout = "~/Views/Shared/_LecturerLayout.cshtml";
}

<div class="page-header">
    <div>
        <h1>My Students</h1>
        <p>Students enrolled in your modules.</p>
    </div>
</div>

<div class="card">
    <div class="card-header-custom">
        <h5><i class="bi bi-people-fill me-2" style="color:var(--primary);"></i>Student List</h5>
        <span class="badge-custom badge-active">@Model.Count() students</span>
    </div>
    <div style="overflow-x:auto;">
        <table class="table-custom">
            <thead>
                <tr>
                    <th>#ID</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var student in Model)
                {
                    <tr>
                        <td>#@student.UserID</td>
                        <td><strong>@student.Title @student.Name @student.Surname</strong></td>
                        <td>@student.Email</td>
                        <td>
                            <a href="/Lecturer/StudentDetails?studentId=@student.UserID" class="btn-primary-custom" style="padding:6px 14px; font-size:13px;">
                                <i class="bi bi-eye"></i> View Assessments
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>