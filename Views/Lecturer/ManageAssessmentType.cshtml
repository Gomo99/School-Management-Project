@model IEnumerable<SchoolProject.Models.AssessmentType>
@{
    ViewData["Title"] = "Assessment Types";
    Layout = "~/Views/Shared/_LecturerLayout.cshtml";
}

<div class="page-header">
    <div>
        <h1>Assessment Types</h1>
        <p>Manage the types of assessments (e.g., Assignment, Test).</p>
    </div>
    <a href="/Lecturer/AddAssessmentType" class="btn-primary-custom">
        <i class="bi bi-plus-circle"></i> New Type
    </a>
</div>

<div class="card">
    <div class="card-header-custom">
        <h5><i class="bi bi-gear-fill me-2" style="color:var(--primary);"></i>All Types</h5>
        <span class="badge-custom badge-active">@Model.Count() types</span>
    </div>
    <div style="overflow-x:auto;">
        <table class="table-custom">
            <thead>
                <tr>
                    <th>#ID</th>
                    <th>Description</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var t in Model)
                    {
                        <tr>
                            <td>#@t.AssessmentTypeID</td>
                            <td><strong>@t.AssessmentTypeDescription</strong></td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a href="/Lecturer/EditAssessmentType/@t.AssessmentTypeID" class="btn-icon edit" title="Edit"><i class="bi bi-pencil"></i></a>
                                    <a href="/Lecturer/DeleteAssessmentType/@t.AssessmentTypeID" class="btn-icon delete" title="Delete"><i class="bi bi-trash"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="text-center py-4" style="color:var(--muted);">
                            <i class="bi bi-inbox" style="font-size:28px; display:block; margin-bottom:6px;"></i>
                            No assessment types defined.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>