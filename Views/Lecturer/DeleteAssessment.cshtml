@model SchoolProject.Models.Assessment
@{
    ViewData["Title"] = "Delete Assessment";
    Layout = "~/Views/Shared/_LecturerLayout.cshtml";
}

<div class="delete-card">
    <div class="card">
        <div class="card-body-custom text-center" style="padding:40px;">
            <div class="delete-icon-wrap"><i class="bi bi-exclamation-triangle-fill"></i></div>
            <h3>Delete Assessment?</h3>
            <p>This will remove the assessment for <strong>@Model.StudentModule?.Student?.Name @Model.StudentModule?.Student?.Surname</strong>.</p>
            <form asp-action="DeleteAssessment" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.AssessmentID" />
                <div class="d-flex gap-3 justify-content-center">
                    <a href="/Lecturer/ManageAssessments" class="btn-secondary-custom">Cancel</a>
                    <button type="submit" class="btn-danger-custom"><i class="bi bi-trash"></i> Delete</button>
                </div>
            </form>
        </div>
    </div>
</div>