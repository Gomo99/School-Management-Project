@using SchoolProject.Status
@model IEnumerable<SchoolProject.Models.Assessment>
@{
    ViewData["Title"] = "All Assessments";
    Layout = "~/Views/Shared/_LecturerLayout.cshtml";
}

<div class="page-header">
    <div>
        <h1>All Assessments</h1>
        <p>Assessments you've created for your modules.</p>
    </div>
    <a href="/Lecturer/AddAssessment" class="btn-primary-custom">
        <i class="bi bi-plus-circle"></i> New Assessment
    </a>
</div>

<div class="card">
    <div class="card-header-custom">
        <h5><i class="bi bi-list-check me-2" style="color:var(--primary);"></i>Assessments</h5>
        <span class="badge-custom badge-active">@Model.Count() records</span>
    </div>
    <div style="overflow-x:auto;">
        <table class="table-custom">
            <thead>
                <tr>
                    <th>Student</th>
                    <th>Module</th>
                    <th>Type</th>
                    <th>Due Date</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var a in Model)
                    {
                        <tr>
                            <td>@a.StudentModule?.Student?.Name @a.StudentModule?.Student?.Surname</td>
                            <td>@a.StudentModule?.LecturerModule?.Module?.ModuleName</td>
                            <td>@a.AssessmentType?.AssessmentTypeDescription</td>
                            <td>@a.DueDate.ToString("dd MMM yyyy")</td>
                            <td>
                                @switch (a.AssessmentStatus)
                                {
                                    case AssessmentStatus.Completed:
                                        <span class="badge-custom badge-completed">Completed</span>
                                        break;
                                    case AssessmentStatus.Missed:
                                        <span class="badge-custom badge-missed">Missed</span>
                                        break;
                                    case AssessmentStatus.Rescheduled:
                                        <span class="badge-custom badge-rescheduled">Rescheduled</span>
                                        break;
                                    default:
                                        <span class="badge-custom badge-notstarted">Not Started</span>
                                        break;
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a href="/Lecturer/EditAssessment/@a.AssessmentID" class="btn-icon edit" title="Edit"><i class="bi bi-pencil"></i></a>
                                    <a href="/Lecturer/DeleteAssessment/@a.AssessmentID" class="btn-icon delete" title="Delete"><i class="bi bi-trash"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center py-4" style="color:var(--muted);">
                            <i class="bi bi-inbox" style="font-size:28px; display:block; margin-bottom:6px;"></i>
                            No assessments found.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>